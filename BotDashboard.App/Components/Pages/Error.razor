@page "/error"
@using BotDashboard.App.Components.Layout
@layout MainLayout

<PageTitle>Error</PageTitle>

<MudContainer Class="d-flex justify-center align-center" Style="height:80vh;">
    <MudPaper Elevation="2" Class="pa-6 text-center main-site-card">
        <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Error" Size="Size.Large" />
        <MudText Typo="Typo.h4" Class="mt-3">Something went wrong</MudText>
        <MudText Class="mb-4">
            An unexpected error occurred while processing your request.
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Tertiary" OnClick="GoHome">
            Go Home
        </MudButton>
    </MudPaper>
</MudContainer>

@code {
    [Inject] NavigationManager NavigationManager { get; set; }
    
    private void GoHome()
    {
        NavigationManager.NavigateTo("/");
    }
}